*.jks
*.keystore

# Env files
.env
.env.*
!.env.example

# Flutter old/generated files (互換目的)
.flutter-plugins
.packages

# iOS user-specific files
ios/**/xcuserdata/
*.xcuserstate

# FVMを使う場合（SDK本体は除外）
.fvm/flutter_sdk

